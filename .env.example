# ─── Database ──────────────────────────────────────────────
# SQLite (default - tezda boshlash uchun):
DATABASE_URL=sqlite+aiosqlite:///./visiontrack.db
# PostgreSQL misol:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/visiontrack

# ─── JWT / xavfsizlik ─────────────────────────────────────
# DIQQAT: Production'da albatta o'zgartiring (kamida 32 belgi tasodifiy).
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────
# Vergul bilan ajratilgan ro'yxat. "*" ishlatmang (credentials bilan ishlamaydi).
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://localhost:5173

# ─── Fayl yuklash ─────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=15

# ─── OCR ──────────────────────────────────────────────────
# Variantlar: auto | groq | easyocr
OCR_BACKEND=auto
# auto rejimida: GROQ_API_KEY bo'lsa Groq Vision, bo'lmasa EasyOCR
GROQ_API_KEY=
GROQ_MODEL=llama-3.2-90b-vision-preview
OCR_LANGUAGES=en
OCR_GPU=false
OCR_MIN_CONFIDENCE=0.5

# ─── Default seed foydalanuvchilar (scripts/seed.py) ──────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_OPERATOR_USERNAME=operator1
SEED_OPERATOR_PASSWORD=op123
